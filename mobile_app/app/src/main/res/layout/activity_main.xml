<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.MainActivity" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#990f172a" />

    <!-- Search Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#1e293b"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search destination..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="12dp"
                android:textColor="#ffffff"
                android:textColorHint="#94a3b8" />

            <ImageButton
                android:id="@+id/searchButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#38bdf8" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Nearby Filter Buttons -->
    <HorizontalScrollView
        android:id="@+id/nearbyFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/searchCard">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPolice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Police"
                android:textColor="#ffffff"
                app:chipBackgroundColor="#1e293b"
                app:chipIcon="@android:drawable/ic_menu_myplaces"
                app:chipIconTint="#38bdf8" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHospital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Hospital"
                android:textColor="#ffffff"
                app:chipBackgroundColor="#1e293b"
                app:chipIcon="@android:drawable/ic_menu_add"
                app:chipIconTint="#38bdf8" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPharmacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Pharmacy"
                android:textColor="#ffffff"
                app:chipBackgroundColor="#1e293b"
                app:chipIcon="@android:drawable/ic_menu_edit"
                app:chipIconTint="#38bdf8" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Top Action Bar Info -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topInfoBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/nearbyFilters">

        <TextView
            android:id="@+id/riskLevelValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAFE"
            android:textColor="#10b981"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/nightModeSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Night Mode"
            android:textColor="#94a3b8"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/contactsButton"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/contactsButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contacts"
            android:textColor="#38bdf8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/sosButton"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/sos_button_gradient"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:text="SOS"
        android:textColor="#ffffff"
        android:textSize="40sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:cornerRadius="100dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topInfoBar"
        app:rippleColor="#FFFFFF" />

    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/recordButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="Record"
            android:textAllCaps="false"
            app:backgroundTint="#1e293b"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/safetyPathButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="Path"
            android:textAllCaps="false"
            app:backgroundTint="#1e293b"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
